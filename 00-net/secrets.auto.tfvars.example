# Copy to `secrets.auto.tfvars` (gitignored) and fill in real values.
#
# UniFi controller credentials the bootstrap stage authenticates with. This is
# a local UniFi account with network-edit rights; the api_url it talks to is
# net.unifi_api_url in nova.yaml (non-secret).
unifi_username = "nova-bootstrap"
unifi_password = "REPLACE_ME"
