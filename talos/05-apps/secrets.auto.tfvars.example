# Copy to `secrets.auto.tfvars` (gitignored) and fill in real values.
# App image/chart versions and ingress settings come from nova.yaml via
# `make generate`.

# Password for the Immich postgres user. Consumed by both the postgres
# StatefulSet and the immich-server pods. Must stay stable across reboots —
# changing it after first apply breaks auth against the existing data dir.
immich_postgres_password = "REPLACE_ME"

# Optional: Argon2id hash of the Vaultwarden admin token. Empty disables the
# admin panel. Generate with `docker run --rm vaultwarden/server /vaultwarden hash`.
# vaultwarden_admin_token = "$argon2id$..."

# Spotify application credentials for your_spotify. Create an app at
# https://developer.spotify.com/dashboard, then add this Redirect URI to it:
#   https://api-spotify.rhysperry.com/oauth/spotify/callback
# SPOTIFY_PUBLIC is the Client ID; SPOTIFY_SECRET is the Client Secret.
your_spotify_public = "REPLACE_ME"
your_spotify_secret = "REPLACE_ME"
