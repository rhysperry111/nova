# Copy to `secrets.auto.tfvars` (gitignored) and fill in real values.
# The non-secret R2 identifiers (account_id, bucket) and Velero versions come
# from nova.yaml via `make generate`.

# Cloudflare R2 API token credentials. Create at:
#   R2 > Manage R2 API Tokens > Create API Token.
#   Permission: Object Read & Write, scoped to the bucket (r2.bucket in nova.yaml).
# The Access Key ID + Secret Access Key are shown ONCE on creation.
r2_access_key_id     = "REPLACE_ME"
r2_secret_access_key = "REPLACE_ME"
