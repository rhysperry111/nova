# Copy to `secrets.auto.tfvars` (gitignored) and fill in real values.
# All non-secret config for this stage (versions, domains, acme_email,
# external-dns settings, unifi_api_url) comes from nova.yaml via `make generate`.

# Cloudflare API token shared by cert-manager (DNS-01) and external-dns.
# Scope: Zone:Zone:Read + Zone:DNS:Edit on the zones you manage.
# Create at: https://dash.cloudflare.com/profile/api-tokens
cloudflare_api_token = "REPLACE_ME"

# UniFi API key used by the external-dns UniFi webhook (internal DNS records).
unifi_api_key = "REPLACE_ME"

# Initial Grafana admin password. Rotate after first login.
grafana_admin_password = "REPLACE_ME"

# AlertMananager discord webhook URL
alertmanager_discord_webhook = "REPLACE_ME"
